<?xml version="1.0" encoding="UTF-8"?>
<sonar version="0.2.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="sonar-script.xsd">
    <synthesis id="output" duration="0.35" normalize="true">
        <initialize>
            <linear min="2800" max="-200" />
        </initialize>
        <mod-freq>
            <waveform type="rect" frequency="300" amplitude="1.0"/>
            <waveform type="rect" frequency="400" amplitude="0.6"/>
            <waveform type="sawtooth" frequency="200" amplitude="0.7"/>
        </mod-freq>
        <mod-amp method="multiply">
            <waveform type="sine" frequency="400" offset="1"/>
        </mod-amp>
        <mod-amp method="add">
            <waveform type="noise" frequency="1" />
        </mod-amp>
        <mod-amp method="multiply">
            <hull attack="10%" sustain="10%" sustain-level="-1dB" min="-60dB" max="0dB"/>
        </mod-amp>
        <hall room-size="0.5" decay="1.5" wet="0" />
    </synthesis>
</sonar>
