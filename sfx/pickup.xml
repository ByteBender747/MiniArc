<?xml version="1.0" encoding="UTF-8"?>
<sonar version="0.2.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="sonar-script.xsd">
    <synthesis id="tone" duration="0" normalize="true">
        <initialize>
            <waveform type="sine" frequency="0" />
        </initialize>
        <mod-amp method="add">
            <waveform type="sawtooth" frequency="0" amplitude="-12dB"/>
            <waveform type="rect" frequency="0" amplitude="-25dB"/>
            <waveform type="sawtooth" frequency="0" amplitude="-16dB" phase="90"/>
        </mod-amp>
    </synthesis>
    <synthesis id="output" duration="0">
        <initialize>
            <sequence import="tone" octave="4">30(C#DD#E)</sequence>
        </initialize>
    </synthesis>
</sonar>
